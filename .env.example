# Tutti — backend auth secrets. Copy to `.env` and fill in. The Supabase CLI reads these
# for the env(...) references in supabase/config.toml. Never commit the real .env.
#
# Google: Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
#
# Apple: developer.apple.com → Services ID (client_id) + a signed client-secret JWT.
SUPABASE_AUTH_APPLE_CLIENT_ID=
SUPABASE_AUTH_APPLE_SECRET=
